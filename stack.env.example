### 参考 docker-compose.yml 文件
## 必填你的 Telegram Bot Token
TOKEN=

## postgres 环境变量
## 数据库名称
POSTGRES_DB=bilifeedbot
## 数据库用户名
POSTGRES_USER=bilifeedbot
## 数据库密码
POSTGRES_PASSWORD=bilifeedbot

## telegram-bot-api 环境变量, 详见 https://core.telegram.org/api/obtaining_api_id
## 设置为 1 以在本地模式下运行（使用本地 Bot API 服务器）
TELEGRAM_LOCAL=1
## 你的 Telegram API ID
TELEGRAM_API_ID=17349
## 你的 Telegram API Hash
TELEGRAM_API_HASH=344583e45741c457fe1862106095a5eb
## 为 telegram-bot-api 启用统计服务器
# TELEGRAM_STAT=
## telegram-bot-api 的日志详细级别
# TELEGRAM_VERBOSITY=

## telegram-bili-feed-helper 环境变量
## 设置为 1 以在本地模式下运行（使用本地 Bot API 服务器）
LOCAL_MODE=1
## 本地 Bot API 服务器的基础 URL
API_BASE_URL=http://telegram-bot-api:8081/bot
## 从本地 Bot API 服务器下载文件的基础 URL
API_BASE_FILE_URL=http://telegram-bot-api:8081/file/bot
## 本地 Bot API 服务器使用的临时文件路径
LOCAL_TEMP_FILE_PATH=/var/lib/telegram-bot-api
## Redis 连接 URL
REDIS_URL=redis://redis:6379
## PostgreSQL 连接 URL
DATABASE_URL=postgres://bilifeedbot:bilifeedbot@postgres:5432/bilifeedbot
## 你的域名（用于 webhook）
# DOMAIN=
## 监听主机地址（用于 webhook）
# HOST=
## 监听端口（用于 webhook）
# PORT=
## 首选的视频编解码器（例如 avc/hev/av01）
# VIDEO_CODEC=
## 视频大小硬限制（字节）。指定画质（/video <画质>）时若超过此值直接报错提示用户；未指定 VIDEO_DOWNGRADE_SIZE 时也作为自动模式上限
# VIDEO_SIZE_LIMIT=
## 视频自动降档大小阈值（字节）。自动模式下下载前先探测体积，超过则逐档降低画质；连最低档都超过则改发封面图。不配置则沿用旧行为（以 VIDEO_SIZE_LIMIT 为准且不回退封面）
# VIDEO_DOWNGRADE_SIZE=
## 超长图切割阈值（高宽比）。动态里高宽比超过此值的长图会按高度切成多张正常比例图发送（默认 2）
# IMAGE_SPLIT_RATIO=2
## 单张超长图切割后的最大片数（Telegram 单组媒体上限 10，默认 10）
# IMAGE_SPLIT_MAX_PIECES=10
## 文件数据库表名
# FILE_TABLE=
## Bilibili API 端点 URL 前缀列表, 逗号分隔
# BILI_API=
## Bilibili UPOS（上传服务器）域名列表, 逗号分隔
# UPOS_DOMAIN=
## FFmpeg 可执行文件路径
# FFMPEG_PATH=
## 文件下载专用代理 URL（如果需要）
# FILE_PROXY=
## 媒体文件连接超时（秒）
# FILE_CONNECT_TIMEOUT=30
## 媒体文件单次读取等待超时（秒）；大视频或慢速 CDN 可继续调大
# FILE_READ_TIMEOUT=60
## 媒体文件写入超时（秒）
# FILE_WRITE_TIMEOUT=60
## 媒体文件连接池等待超时（秒）
# FILE_POOL_TIMEOUT=30
## HTTP 代理 URL（例如 http://user:pass@host:port 或 socks5://host:port）
# HTTP_PROXY=
## 处理任务的并发限制
# SEMAPHORE_SIZE=
## 上传工作线程数
# UPLOAD_WORKERS=4
## 上传队列总大小
# MAX_QUEUE_SIZE=200
## 单用户/群组最大上传任务队列数
# MAX_USER_TASKS=5
## API 最大重试次数
# API_MAX_RETRIES=5
## 单用户/群组限流窗口内请求上限，0 或留空表示不限制
# REQUEST_LIMIT_COUNT=0
## 单用户/群组限流窗口 TTL（秒），例如 86400 表示 24 小时
# REQUEST_LIMIT_TTL=86400
## 上传媒体最大重试次数（网络超时等错误，按指数退避重试）
# UPLOAD_MAX_RETRIES=4
## 上传大体积视频的写入超时（秒），默认 600，上传容易超时可调大
# MEDIA_WRITE_TIMEOUT=600
## Telegram API 读取超时（秒）
# READ_TIMEOUT=60
## Telegram API 写入超时（秒）
# WRITE_TIMEOUT=120
## Telegram API 连接超时（秒）
# CONNECT_TIMEOUT=60
## Telegram API 连接池等待超时（秒）
# POOL_TIMEOUT=60
## 设置为 1 以启用文件日志记录
# LOG_TO_FILE=
## 用于创建 Telegraph 页面的 Telegraph 访问令牌
# TELEGRAPH_ACCESS_TOKEN=
## 凭据缓存的生存时间（秒）
# CREDENTIAL_CACHE_TIME=
## 锁缓存的生存时间（秒）
# LOCK_CACHE_TIME=
## 音频数据缓存的生存时间（秒）
# AUDIO_CACHE_TIME=
## 番剧数据缓存的生存时间（秒）
# BANGUMI_CACHE_TIME=
## Opus 数据缓存的生存时间（秒）
# OPUS_CACHE_TIME=
## 直播流数据缓存的生存时间（秒）
# LIVE_CACHE_TIME=
## 已读状态缓存的生存时间（秒）
# READ_CACHE_TIME=
## 回复数据缓存的生存时间（秒）
# REPLY_CACHE_TIME=
## 视频数据缓存的生存时间（秒）
# VIDEO_CACHE_TIME=

#### BEGIN: Bilibili Cookie
## 管理员 Telegram 用户 ID。管理员通过 /login 扫码更新 Bilibili 凭证
# ADMIN_USER_ID=
## Bilibili SESSDATA
# SESSDATA=
## Bilibili CSRF 令牌
# BILI_JCT=
## Bilibili BUVID3
# BUVID3=
## Bilibili BUVID4
# BUVID4=
## Bilibili 用户 ID
# DEDEUSERID=
## Bilibili AC_TIME_VALUE
# AC_TIME_VALUE=
#### END: Bilibili Cookie
